# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3001

# ─────────────────────────────────────────────
# Database (PostgreSQL via Docker)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://callassistant:callassistant@localhost:5432/callassistant?schema=public"

# ─────────────────────────────────────────────
# Redis (via Docker)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# Clerk Authentication
# Get from https://dashboard.clerk.com
# ─────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# Stripe
# Get from https://dashboard.stripe.com
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# Razorpay
# Get from https://dashboard.razorpay.com
# ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# AI Providers (Optional — stub if not used)
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# Internal secrets (shared between web app and backend)
# ─────────────────────────────────────────────
# Generate: openssl rand -hex 32
INTERNAL_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# Session Settings
# ─────────────────────────────────────────────
# How often the client sends heartbeats (seconds)
SESSION_HEARTBEAT_INTERVAL_SECONDS=30
# After this many seconds without a heartbeat, session is marked stale
SESSION_STALE_THRESHOLD_SECONDS=300
