  "version": "1.0.0",
  "description": "AI Call & Interview Assistant — Production Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
